                        <td style="padding: 12px; color: #718096;">${m.regDate || '---'}</td>
                        <td style="padding: 12px; font-weight: bold; color: #047857;">₦${(m.deposit || 0).toLocaleString()}</td>
                        <td style="padding: 12px; color: #4a5568;">${m.phone}</td>
                        <td style="padding: 12px; color: #4a5568;">${m.bank}</td>
