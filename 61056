                `;
            });

            const printArea = document.getElementById('print-area');
            printArea.innerHTML = `
                <div style="font-family: 'Inter', sans-serif; padding: 30px; background-color: #ffffff;">
                    <div style="text-align: center; margin-bottom: 25px;">
                        <h2 style="color: #047857; margin: 0; font-size: 24px; font-weight: bold; letter-spacing: -0.5px;">FRIENDS INFORMATION MANAGEMENT PORTAL</h2>
                        <p style="color: #718096; margin: 5px 0 0 0; font-size: 14px;">Official Registered Members Registry Roster</p>
                        <p style="color: #a0aec0; margin: 2px 0 0 0; font-size: 11px;">Date Generated: ${new Date().toLocaleDateString()}</p>
                    </div>
                    <table style="width: 100%; border-collapse: collapse; text-align: left;" border="0">
                        <thead>
                            <tr style="background-color: #f7fafc; border-bottom: 2px solid #e2e8f0; font-size: 12px; color: #4a5568; text-transform: uppercase; font-weight: bold;">
                                <th style="padding: 12px; text-align: center; width: 8%;">S/N</th>
                                <th style="padding: 12px; width: 25%;">Full Name</th>
                                <th style="padding: 12px; width: 15%;">Reg Date</th>
                                <th style="padding: 12px; width: 18%;">Total Deposited</th>
                                <th style="padding: 12px; width: 17%;">Phone</th>
                                <th style="padding: 12px; width: 20%;">Bank Account Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${rowsHtml || '<tr><td colspan="6" style="padding: 20px; text-align: center; color: #a0aec0; italic">No registered members found in database.</td></tr>'}
                        </tbody>
                    </table>
                </div>
            `;

            printArea.classList.remove('hidden');
            window.print();
            
            setTimeout(() => {
                printArea.classList.add('hidden');
                printArea.innerHTML = '';
            }, 500);
        }

        function printUserProfileReport() {
            const u = APP_MEMBERS.find(m => m.id === CURRENT_SESSION_USER.id);
            const printArea = document.getElementById('print-area');

            printArea.innerHTML = `
                <div style="font-family: sans-serif; padding: 40px; background: white; border: 1px solid #e2e8f0;">
                    <h1 style="color: #047857; text-align: center; font-size: 22px;">MEMBER STATEMENT OF CONTRIBUTION</h1>
                    <hr style="border:0; border-top: 1px solid #e2e8f0; margin: 20px 0;"/>
                    <p style="font-size:14px;"><strong>Full Name:</strong> ${u.name}</p>
                    <p style="font-size:14px;"><strong>Registration Date:</strong> ${u.regDate || '---'}</p>
                    <p style="font-size:14px;"><strong>Bank Grid Location:</strong> ${u.bank}</p>
                    <div style="background: #f0fdf4; padding: 20px; border-radius: 8px; margin-top:20px; border: 1px solid #bbf7d0;">
                        <h2 style="margin:0; font-size:18px; color:#047857;">Total Contributed Pool Inflow: ₦${(u.deposit || 0).toLocaleString()}</h2>
                    </div>
                </div>
            `;
            printArea.classList.remove('hidden');
            window.print();
            setTimeout(() => {
                printArea.classList.add('hidden');
                printArea.innerHTML = '';
            }, 500);
        }
    </script>
