    <script>
        const DEFAULT_SEED_MEMBERS = [
            { 
                id: "admin_root", 
                name: "Anas Mamudo", 
                username: "anas_admin", 
                email: "admin@app.com", 
                password: "07050349", 
                phone: "+2348012345678", 
                bank: "0123456789 - Access Bank", 
                dob: "1995-04-12", 
                gender: "Male", 
                notes: "Primary Root Administrator Platform Manager", 
                role: "admin", 
                avatar: "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100' height='100' viewBox='0 0 100 100'><circle cx='50' cy='50' r='50' fill='%23047857'/><text x='50%25' y='55%25' font-size='35' fill='white' font-family='sans-serif' text-anchor='middle' font-weight='bold'>AM</text></svg>", 
                deposit: 0,
                regDate: "2026-01-01"
            }
        ];

        let APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS'));
        if (!APP_MEMBERS || APP_MEMBERS.length === 0) {
            APP_MEMBERS = DEFAULT_SEED_MEMBERS;
            localStorage.setItem('CORE_MEMBERS', JSON.stringify(APP_MEMBERS));
        } else {
            let rootAdmin = APP_MEMBERS.find(m => m.id === "admin_root");
            if (rootAdmin) { rootAdmin.password = "07050349"; }
        }

        let GLOBAL_POOL_WITHDRAWALS = parseFloat(localStorage.getItem('GLOBAL_POOL_WITHDRAWAL_BAL')) || 0;
        let APP_TRANSACTIONS = JSON.parse(localStorage.getItem('CORE_TXS')) || [];
        let APP_UPDATES = JSON.parse(localStorage.getItem('CORE_UPDATES')) || [];
        let CURRENT_SESSION_USER = null;

        function commitDatabaseUpdate() {
            localStorage.setItem('CORE_MEMBERS', JSON.stringify(APP_MEMBERS));
            localStorage.setItem('CORE_TXS', JSON.stringify(APP_TRANSACTIONS));
            localStorage.setItem('CORE_UPDATES', JSON.stringify(APP_UPDATES));
            localStorage.setItem('GLOBAL_POOL_WITHDRAWAL_BAL', GLOBAL_POOL_WITHDRAWALS.toString());
        }

        function triggerPopUpModal(title, messageHtml, type = "success") {
            const container = document.getElementById('universal-modal');
            const iconBox = document.getElementById('modal-icon-container');
            const titleBox = document.getElementById('modal-title');
            const bodyBox = document.getElementById('modal-body-content');

            titleBox.innerText = title;
            bodyBox.innerHTML = messageHtml;

            if (type === "success") {
                iconBox.className = "w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl bg-emerald-100 text-emerald-600";
                iconBox.innerHTML = `<i class="fa-solid fa-circle-check"></i>`;
            } else if (type === "alert") {
                iconBox.className = "w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl bg-amber-100 text-amber-600";
                iconBox.innerHTML = `<i class="fa-solid fa-bell"></i>`;
            } else {
                iconBox.className = "w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl bg-blue-100 text-blue-600";
                iconBox.innerHTML = `<i class="fa-solid fa-circle-info"></i>`;
            }

            container.classList.remove('hidden');
        }

        function closeUniversalModal() {
            document.getElementById('universal-modal').classList.add('hidden');
        }

        function navigateTo(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            if(pageId === 'page-login' || pageId === 'page-register') {
                document.getElementById('top-nav').style.display = 'none';
            } else {
                document.getElementById('top-nav').style.display = 'flex';
            }
            window.scrollTo(0,0);
        }

        function switchUserTab(tabName) {
            if(tabName === 'dashboard') {
                if(CURRENT_SESSION_USER.role === 'admin') {
                    renderAdminDashboard();
                    navigateTo('page-admin-dashboard');
                } else {
                    renderUserDashboard();
                    navigateTo('page-user-dashboard');
                }
            } else if(tabName === 'updates') {
                renderUpdatesHub();
                navigateTo('page-updates-hub');
            }
        }

        function togglePasswordChangeView() {
            const div = document.getElementById('pass-change-fields');
            div.classList.toggle('hidden');
        }

        function processUserPasswordMutation() {
            const field = document.getElementById('user-new-pass');
            const val = field.value.trim();
            if(val.length < 6) {
                alert("Kuskure: Kalmar sirri dole ta kai tsawon akalla harafi 6.");
                return;
            }
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            const idx = APP_MEMBERS.findIndex(m => m.id === CURRENT_SESSION_USER.id);
            if(idx !== -1) {
                APP_MEMBERS[idx].password = val;
                CURRENT_SESSION_USER.password = val;
                commitDatabaseUpdate();
                alert("An sauya kalmar sirrinka cikin nasara!");
                field.value = '';
                togglePasswordChangeView();
            }
        }

        function showDonationContainer() {
            document.getElementById('user-donation-container').classList.remove('hidden');
            document.getElementById('user-profile-card').classList.add('hidden');
        }

        function hideDonationContainer() {
            document.getElementById('user-donation-container').classList.add('hidden');
            document.getElementById('user-profile-card').classList.remove('hidden');
        }

        function handleLogin(e) {
            e.preventDefault();
            const targetEmail = document.getElementById('login-email').value.trim().toLowerCase();
            const targetPassword = document.getElementById('login-password').value;

            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            const matchingProfile = APP_MEMBERS.find(user => user.email.toLowerCase() === targetEmail);

            if (!matchingProfile) {
                alert("Authentication Failed: Email address not found.");
                return;
            }

            if (matchingProfile.password !== targetPassword) {
                alert("Authentication Failed: Invalid password.");
                return;
            }

            CURRENT_SESSION_USER = matchingProfile;
            document.getElementById('user-display-name').innerText = `User: ${matchingProfile.name}`;

            triggerPopUpModal(
                "Access Granted!",
                `<p class="text-center text-gray-700 font-medium">Welcome back, <strong>${matchingProfile.name}</strong>!</p>`,
                "success"
            );

            updateAlertBadgeInterface();

            if (matchingProfile.role === 'admin') {
                renderAdminDashboard();
                navigateTo('page-admin-dashboard');
            } else {
                renderUserDashboard();
                navigateTo('page-user-dashboard');
            }
            
            document.getElementById('login-email').value = '';
            document.getElementById('login-password').value = '';
        }

        function updateAlertBadgeInterface() {
            APP_UPDATES = JSON.parse(localStorage.getItem('CORE_UPDATES')) || [];
            let unseenCount = APP_UPDATES.filter(item => !item.seenBy.includes(CURRENT_SESSION_USER.name)).length;
            const badge = document.getElementById('update-badge');
            if(unseenCount > 0) {
                badge.innerText = unseenCount;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        function handleRegister(e) {
            e.preventDefault();
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            
            let emailValue = document.getElementById('reg-email').value.trim().toLowerCase();
            let nameValue = document.getElementById('reg-name').value.trim();
            let usernameValue = document.getElementById('reg-username').value.trim();
            let passwordValue = document.getElementById('reg-pass').value;
            let phoneValue = document.getElementById('reg-phone').value.trim();
            let bankValue = document.getElementById('reg-bank').value.trim();
            let dobValue = document.getElementById('reg-dob').value;
            let genderValue = document.getElementById('reg-gender').value;
            let notesValue = document.getElementById('reg-notes').value.trim();

            if (APP_MEMBERS.some(u => u.email.toLowerCase() === emailValue)) {
                alert("Registration Error: Email already exists.");
                return;
            }

            const defaultAvatar = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100' height='100' viewBox='0 0 100 100'><circle cx='50' cy='50' r='50' fill='%236b7280'/><text x='50%25' y='55%25' font-size='35' fill='white' font-family='sans-serif' text-anchor='middle'>U</text></svg>";

            const finalizeAndSave = (avatarToSave) => {
                const today = new Date().toISOString().split('T')[0];
                const freshMemberRecord = {
                    id: "usr_" + Date.now(),
                    name: nameValue,
                    username: usernameValue,
                    email: emailValue,
                    password: passwordValue,
                    phone: phoneValue,
                    bank: bankValue,
                    dob: dobValue,
                    gender: genderValue,
                    notes: notesValue,
                    role: "member",
                    avatar: avatarToSave,
                    deposit: 0,
                    hasUnreadWithdrawal: false, 
                    lastWithdrawalAmount: 0,
                    regDate: today
                };

                APP_MEMBERS.push(freshMemberRecord);
                localStorage.setItem('CORE_MEMBERS', JSON.stringify(APP_MEMBERS));
                
                triggerPopUpModal("Registration Records Saved", `<p class='text-center'>Account registered successfully for ${nameValue}!</p>`, "success");
                document.getElementById('main-registration-form').reset();
                navigateTo('page-login');
            };

            let fileInput = document.getElementById('reg-pic');
            if (fileInput && fileInput.files && fileInput.files[0]) {
                const reader = new FileReader();
                reader.onload = function(event) { finalizeAndSave(event.target.result); };
                reader.onerror = function() { finalizeAndSave(defaultAvatar); };
                reader.readAsDataURL(fileInput.files[0]);
            } else {
                finalizeAndSave(defaultAvatar);
            }
        }

        function logout() {
            CURRENT_SESSION_USER = null;
            navigateTo('page-login');
        }

        function renderUserDashboard() {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            APP_TRANSACTIONS = JSON.parse(localStorage.getItem('CORE_TXS')) || [];
            GLOBAL_POOL_WITHDRAWALS = parseFloat(localStorage.getItem('GLOBAL_POOL_WITHDRAWAL_BAL')) || 0;
            
            const u = APP_MEMBERS.find(m => m.id === CURRENT_SESSION_USER.id);
            if(!u) return logout();
            
            let nonAdminMembers = APP_MEMBERS.filter(m => m.role !== 'admin');
            let totalInflows = nonAdminMembers.reduce((sum, m) => sum + (m.deposit || 0), 0);
            let netPoolCapital = totalInflows - GLOBAL_POOL_WITHDRAWALS;

            document.getElementById('user-bal').innerText = `₦${(u.deposit || 0).toLocaleString()}`;
            document.getElementById('user-group-net').innerText = `₦${netPoolCapital.toLocaleString()}`;
            document.getElementById('user-group-out').innerText = `₦${GLOBAL_POOL_WITHDRAWALS.toLocaleString()}`;

            document.getElementById('user-avatar').src = u.avatar;
            document.getElementById('user-profile-name').innerText = u.name;
            document.getElementById('user-profile-username').innerText = `@${u.username}`;
            document.getElementById('user-profile-phone').innerText = u.phone;
            document.getElementById('user-profile-bank').innerText = u.bank;
            document.getElementById('user-profile-dob').innerText = u.dob;
            document.getElementById('user-profile-gender').innerText = u.gender;

            if (u.hasUnreadWithdrawal) {
                const alertHtml = `
                    <div class="bg-emerald-50 p-4 border border-emerald-200 rounded-xl text-left text-xs space-y-2">
                        <p class="text-emerald-800 font-bold">🎉 Payout rotation disbursed to your account!</p>
                        <p><strong>Amount Transferred:</strong> <span class="text-emerald-700 font-bold">₦${u.lastWithdrawalAmount.toLocaleString()}</span></p>
                    </div>
                `;
                triggerPopUpModal("Group Contribution Payout Received", alertHtml, "success");
                u.hasUnreadWithdrawal = false;
                commitDatabaseUpdate();
            }

            const tableBody = document.getElementById('user-tx-table');
            tableBody.innerHTML = '';
            
            const records = APP_TRANSACTIONS.filter(t => t.userId === u.id || t.type === "Group Payout");
            if(records.length === 0) {
                tableBody.innerHTML = `<tr><td colspan="6" class="p-4 text-center text-gray-400 italic">No transactions loaded.</td></tr>`;
                return;
            }

            records.sort((a,b) => b.txId.localeCompare(a.txId)).forEach(t => {
                let badge = t.status === 'Approved' ? "bg-emerald-100 text-emerald-800" : (t.status === 'Rejected' ? "bg-red-100 text-red-800" : "bg-amber-100 text-amber-800");
                let displayType = t.type === "Group Payout" ? "🎁 Disbursed Payout" : t.type;
                let txColor = t.type === "Group Payout" ? "text-red-600" : "text-gray-900";

                tableBody.innerHTML += `
                    <tr class="hover:bg-gray-50 transition">
                        <td class="p-4 font-mono text-xs text-gray-500">${t.timestamp}</td>
                        <td class="p-4 text-xs font-bold text-gray-700">${displayType}</td>
                        <td class="p-4 text-xs text-gray-600 font-medium">${t.userName}</td>
                        <td class="p-4 font-extrabold ${txColor}">₦${t.amount.toLocaleString()}</td>
                        <td class="p-4 text-gray-600">${t.note}</td>
                        <td class="p-4 text-center"><span class="px-2 py-0.5 rounded-full text-xs font-bold ${badge}">${t.status}</span></td>
                    </tr>
                `;
            });
            updateAlertBadgeInterface();
        }

        function submitTransaction(e) {
            e.preventDefault();
            const inputAmount = parseFloat(document.getElementById('tx-amount').value);
            const inputNote = document.getElementById('tx-note').value.trim() || "Regular Contribution Settlement";

            APP_TRANSACTIONS.push({
                txId: "tx_" + Date.now(),
                userId: CURRENT_SESSION_USER.id,
                userName: CURRENT_SESSION_USER.name,
                amount: inputAmount,
                type: "Deposit",
                note: inputNote,
                status: "Pending",
                timestamp: new Date().toLocaleString()
            });
            
            commitDatabaseUpdate();
            hideDonationContainer();
            renderUserDashboard();

            triggerPopUpModal("Submission Complete", `<p class='text-center text-xs'>Deposit entry of <strong>₦${inputAmount.toLocaleString()}</strong> dispatched for admin verification.</p>`, "info");
            document.getElementById('tx-amount').value = '';
            document.getElementById('tx-note').value = '';
        }

        // NEW FUNCTION TO TOGGLE/HIDE THE POST FORM CONTAINER
        function togglePostFormContainer() {
            const formBox = document.getElementById('posting-form-container');
            const btnText = document.getElementById('toggle-post-text');
            
            if (formBox.classList.contains('hidden')) {
                formBox.classList.remove('hidden');
                btnText.innerText = "Hide Post Form";
            } else {
                formBox.classList.add('hidden');
                btnText.innerText = "Create New Update";
            }
        }

        function handleCreateUpdateBroadcast(e) {
            e.preventDefault();
            APP_UPDATES = JSON.parse(localStorage.getItem('CORE_UPDATES')) || [];
            
            const title = document.getElementById('up-title').value.trim();
            const body = document.getElementById('up-body').value.trim();
            const fileInput = document.getElementById('up-image');

            if(!fileInput.files || !fileInput.files[0]) {
                alert("Please append a document picture graphic.");
                return;
            }

            const reader = new FileReader();
            reader.onload = function(event) {
                const newUpdateItem = {
                    id: "up_" + Date.now(),
                    title: title,
                    body: body,
                    image: event.target.result,
                    author: CURRENT_SESSION_USER.name,
                    timestamp: new Date().toLocaleString(),
                    seenBy: [CURRENT_SESSION_USER.name]
                };

                APP_UPDATES.push(newUpdateItem);
                localStorage.setItem('CORE_UPDATES', JSON.stringify(APP_UPDATES));
                
                document.getElementById('up-title').value = '';
                document.getElementById('up-body').value = '';
                fileInput.value = '';

                // NEW ACTION: Hide the form automatically after successful submission
                document.getElementById('posting-form-container').classList.add('hidden');
                document.getElementById('toggle-post-text').innerText = "Create New Update";

                alert("Important update published to the timeline!");
                renderUpdatesHub();
            };
            reader.readAsDataURL(fileInput.files[0]);
        }

        function renderUpdatesHub() {
            APP_UPDATES = JSON.parse(localStorage.getItem('CORE_UPDATES')) || [];
            const container = document.getElementById('updates-stream-box');
            container.innerHTML = '';

            let stateChanged = false;
            APP_UPDATES.forEach(item => {
                if(!item.seenBy.includes(CURRENT_SESSION_USER.name)) {
                    item.seenBy.push(CURRENT_SESSION_USER.name);
                    stateChanged = true;
                }
            });
            if(stateChanged) {
                localStorage.setItem('CORE_UPDATES', JSON.stringify(APP_UPDATES));
            }
            updateAlertBadgeInterface();

            if(APP_UPDATES.length === 0) {
                container.innerHTML = `<div class='p-8 text-center text-gray-400 italic bg-white rounded-xl border border-gray-100 text-sm'>No board updates posted yet.</div>`;
                return;
            }

            APP_UPDATES.sort((a,b) => b.id.localeCompare(a.id)).forEach(item => {
                let seenListHtml = item.seenBy.map(name => `<span class="bg-gray-100 text-gray-700 px-2 py-0.5 rounded-full text-[10px] border">${name}</span>`).join(' ');

                container.innerHTML += `
                    <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-100 space-y-4">
                        <div class="flex justify-between items-start border-b pb-2">
                            <div>
                                <h5 class="font-bold text-gray-900 text-base">${item.title}</h5>
                                <p class="text-[11px] text-gray-400">Posted by: <span class="font-semibold text-emerald-600">${item.author}</span> • ${item.timestamp}</p>
                            </div>
                        </div>
                        <p class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">${item.body}</p>
                        <div class="max-w-md mx-auto">
                            <img src="${item.image}" class="w-full h-auto max-h-72 object-cover rounded-lg border shadow-inner bg-gray-50">
                        </div>
                        
                        <div class="pt-3 border-t">
                            <p class="text-[11px] font-bold text-gray-400 uppercase tracking-wider mb-1.5"><i class="fa-solid fa-eye text-teal-600"></i> Seen By (${item.seenBy.length}):</p>
                            <div class="flex flex-wrap gap-1.5">
                                ${seenListHtml}
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        function renderAdminDashboard() {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            APP_TRANSACTIONS = JSON.parse(localStorage.getItem('CORE_TXS')) || [];
            GLOBAL_POOL_WITHDRAWALS = parseFloat(localStorage.getItem('GLOBAL_POOL_WITHDRAWAL_BAL')) || 0;

            let nonAdminMembers = APP_MEMBERS.filter(m => m.role !== 'admin');
            
            let totalDepositedAllTime = nonAdminMembers.reduce((sum, m) => sum + (m.deposit || 0), 0);
            let netPoolCapital = totalDepositedAllTime - GLOBAL_POOL_WITHDRAWALS;

            document.getElementById('adm-total-members').innerText = nonAdminMembers.length;
            document.getElementById('adm-total-standard').innerText = `₦${totalDepositedAllTime.toLocaleString()}`;
            document.getElementById('adm-net-bal').innerText = `₦${netPoolCapital.toLocaleString()}`;
            document.getElementById('adm-total-with').innerText = `₦${GLOBAL_POOL_WITHDRAWALS.toLocaleString()}`;

            const pendingContainer = document.getElementById('adm-pending-container');
            pendingContainer.innerHTML = '';
            const pendingItems = APP_TRANSACTIONS.filter(t => t.status === "Pending");

            if(pendingItems.length === 0) {
                pendingContainer.className = "p-6 text-center text-gray-400 italic text-sm";
                pendingContainer.innerHTML = "No pending validation confirmations.";
            } else {
                pendingContainer.className = "p-4 grid grid-cols-1 md:grid-cols-2 gap-4";
                pendingItems.forEach(t => {
                    pendingContainer.innerHTML += `
                        <div class="bg-gray-50 border border-gray-200/60 rounded-xl p-4 flex flex-col justify-between shadow-sm">
                            <div class="space-y-2">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h4 class="text-sm font-bold text-gray-900">${t.userName}</h4>
                                        <p class="text-[10px] font-mono text-gray-400">${t.timestamp}</p>
                                    </div>
                                    <span class="text-xs font-extrabold text-emerald-700 bg-emerald-50 px-2 py-1 rounded-md">₦${t.amount.toLocaleString()}</span>
                                </div>
                                <p class="text-xs text-gray-600">"${t.note}"</p>
                            </div>
                            <div class="flex justify-end space-x-2 pt-3 mt-3 border-t">
                                <button onclick="executeTransactionResolution('${t.txId}', 'Reject')" class="bg-white text-gray-500 border px-2.5 py-1.5 rounded-lg text-xs hover:bg-red-50 hover:text-red-600 transition">Reject</button>
                                <button onclick="executeTransactionResolution('${t.txId}', 'Approve')" class="bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-xs hover:bg-emerald-700 transition shadow-sm">Approve Entry</button>
                            </div>
                        </div>
                    `;
                });
            }

            const membersBody = document.getElementById('adm-members-table');
            membersBody.innerHTML = '';
            const query = document.getElementById('adm-search-input').value.toLowerCase().trim();

            const filteredMembers = nonAdminMembers.filter(m => {
                return m.name.toLowerCase().includes(query) || m.username.toLowerCase().includes(query);
            });

            if(filteredMembers.length === 0) {
                membersBody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-gray-400 italic">No members found.</td></tr>`;
            } else {
                filteredMembers.forEach((m, index) => {
                    membersBody.innerHTML += `
                        <tr class="hover:bg-gray-50 transition text-xs">
                            <td class="p-4 text-center font-bold text-gray-500">${index + 1}</td>
                            <td class="p-4 flex items-center space-x-3">
                                <img src="${m.avatar}" class="w-10 h-10 rounded-full object-cover border">
                                <div>
                                    <p class="font-bold text-gray-900">${m.name}</p>
                                    <p class="text-emerald-600 font-mono">@${m.username}</p>
                                </div>
                            </td>
                            <td class="p-4 text-gray-500 whitespace-nowrap">${m.regDate || '---'}</td>
                            <td class="p-4 font-bold text-emerald-700">₦${(m.deposit || 0).toLocaleString()}</td>
                            <td class="p-4 text-gray-600">${m.phone}</td>
                            <td class="p-4 text-gray-600 truncate max-w-[120px]">${m.bank}</td>
                            <td class="p-4">
                                <div class="flex items-center justify-center space-x-2">
                                    <button onclick="executeAdminChangePassword('${m.id}')" class="bg-white hover:bg-gray-100 text-gray-700 px-2 py-1 rounded border text-[11px] font-medium transition shadow-sm">
                                        <i class="fa-solid fa-key text-gray-400 mr-0.5"></i> Pass
                                    </button>
                                    <button onclick="executeDeleteMember('${m.id}')" class="bg-red-50 hover:bg-red-100 text-red-600 px-2 py-1 rounded border border-red-200 text-[11px] font-medium transition shadow-sm">
                                        <i class="fa-solid fa-trash mr-0.5"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            }
            updateAlertBadgeInterface();
        }

        function executeTransactionResolution(txId, action) {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            APP_TRANSACTIONS = JSON.parse(localStorage.getItem('CORE_TXS')) || [];

            const txIndex = APP_TRANSACTIONS.findIndex(t => t.txId === txId);
            if (txIndex === -1) return;

            const tx = APP_TRANSACTIONS[txIndex];
            const targetUserIndex = APP_MEMBERS.findIndex(m => m.id === tx.userId);

            if(action === 'Approve') {
                tx.status = 'Approved';
                if(targetUserIndex !== -1) {
                    APP_MEMBERS[targetUserIndex].deposit = (APP_MEMBERS[targetUserIndex].deposit || 0) + tx.amount;
                }
            } else {
                tx.status = 'Rejected';
            }

            commitDatabaseUpdate();
            renderAdminDashboard();
        }

        function openAdminGlobalWithdrawalDialog() {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            GLOBAL_POOL_WITHDRAWALS = parseFloat(localStorage.getItem('GLOBAL_POOL_WITHDRAWAL_BAL')) || 0;
            
            let nonAdminMembers = APP_MEMBERS.filter(m => m.role !== 'admin');
            if (nonAdminMembers.length === 0) return alert("No members registered.");

            let totalInflows = nonAdminMembers.reduce((sum, m) => sum + (m.deposit || 0), 0);
            let netPoolCapital = totalInflows - GLOBAL_POOL_WITHDRAWALS;

            let dropdownMenuText = "Select Rotation Recipient:\n\n";
            nonAdminMembers.forEach((m, index) => { dropdownMenuText += `${index + 1}. ${m.name}\n`; });

            const userSelectionInput = prompt(dropdownMenuText);
            if (userSelectionInput === null) return;

            const selectedIndex = parseInt(userSelectionInput) - 1;
            if (isNaN(selectedIndex) || selectedIndex < 0 || selectedIndex >= nonAdminMembers.length) return alert("Invalid choice.");

            const targetedMember = nonAdminMembers[selectedIndex];
            const payoutAmountInput = prompt(`Recipient: ${targetedMember.name}\nBank: ${targetedMember.bank}\nNet Capital: ₦${netPoolCapital.toLocaleString()}\n\nEnter payout amount (₦):`);
            if (payoutAmountInput === null) return;

            const finalWithdrawalAmount = parseFloat(payoutAmountInput);
            if (isNaN(finalWithdrawalAmount) || finalWithdrawalAmount <= 0 || finalWithdrawalAmount > netPoolCapital) return alert("Invalid amount.");

            GLOBAL_POOL_WITHDRAWALS += finalWithdrawalAmount;

            const targetIndexInMasterDatabase = APP_MEMBERS.findIndex(m => m.id === targetedMember.id);
            if (targetIndexInMasterDatabase !== -1) {
                APP_MEMBERS[targetIndexInMasterDatabase].hasUnreadWithdrawal = true;
                APP_MEMBERS[targetIndexInMasterDatabase].lastWithdrawalAmount = finalWithdrawalAmount;
            }

            APP_TRANSACTIONS.push({
                txId: "tx_" + Date.now(),
                userId: targetedMember.id,
                userName: targetedMember.name,
                amount: finalWithdrawalAmount,
                type: "Group Payout",
                note: `Contribution rotation payout disbursed to ${targetedMember.name}`,
                status: "Approved", 
                timestamp: new Date().toLocaleString()
            });

            commitDatabaseUpdate();
            alert("Payout Successful!");
            renderAdminDashboard();
        }

        function executeAdminChangePassword(userId) {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            const idx = APP_MEMBERS.findIndex(m => m.id === userId);
            if (idx === -1) return;

            const newPassword = prompt(`Enter new password for ${APP_MEMBERS[idx].name}:`);
            if (newPassword === null || newPassword.trim().length < 6) return alert("Password must be min 6 chars.");

            APP_MEMBERS[idx].password = newPassword.trim();
            commitDatabaseUpdate();
            alert("Password changed successfully.");
            renderAdminDashboard();
        }

        function executeDeleteMember(userId) {
            if(!confirm("Shin da gaske kake son goge wannan mamba gaba ɗaya daga tsarin?")) return;
            
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
            APP_MEMBERS = APP_MEMBERS.filter(m => m.id !== userId);
            
            localStorage.setItem('CORE_MEMBERS', JSON.stringify(APP_MEMBERS));
            alert("An goge mamba cikin nasara.");
            renderAdminDashboard();
        }

        function printAdminMembersRegistry() {
            APP_MEMBERS = JSON.parse(localStorage.getItem('CORE_MEMBERS')) || DEFAULT_SEED_MEMBERS;
